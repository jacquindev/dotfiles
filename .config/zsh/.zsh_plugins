# Evalcache
mroth/evalcache

# Completions
marlonrichert/zsh-autocomplete
zsh-users/zsh-completions path:src kind:fpath

# Oh-my-zsh
getantidote/use-omz
ohmyzsh/ohmyzsh path:lib/grep.zsh
ohmyzsh/ohmyzsh path:plugins/aliases
