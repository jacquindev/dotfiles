# xdg
XDG_CONFIG_DIRS="/etc/xdg"
XDG_CONFIG_HOME="$HOME/.config"
XDG_CACHE_HOME="$HOME/.cache"
XDG_DATA_HOME="$HOME/.local/share"
XDG_STATE_HOME="$HOME/.local/state"
XDG_BIN_HOME="$HOME/.local/bin"
XDG_RUNTIME_DIR="$HOME/.xdg"
XDG_PROJECTS_DIR="$HOME/projects"

# zsh
ZDOTDIR="$XDG_CONFIG_HOME/zsh"
ZSH_DATA_DIR="$XDG_DATA_HOME/zsh"
ZSH_CACHE_DIR="$XDG_CACHE_HOME/zsh"
ZSH_EVALCACHE_DIR="$XDG_CACHE_HOME/zsh/evalcache"

# Homebrew
# Disable homebrew auto-update for faster homebrew loading
HOMEBREW_NO_AUTO_UPDATE=1

# ripgrep
RIPGREP_CONFIG_PATH="$XDG_CONFIG_HOME/ripgrep/config"

# less
LESSHISTFILE="$XDG_CACHE_HOME/.lesshsts"

# wget
WGETRC="$XDG_CONFIG_HOME/wget/wgetrc"

# nvm
NVM_DIR="$XDG_DATA_HOME/nvm"
PNPM_HOME="$XDG_DATA_HOME/pnpm"
npm_config_cache="$XDG_CACHE_HOME/npm"
YARN_CACHE_FOLDER="$XDG_CACHE_HOME/npm"

# goenv
GOENV_ROOT="$XDG_DATA_HOME/goenv"
GOENV_RC_FILE="$XDG_CONFIG_HOME/.goenvrc"

# pyenv
PYENV_ROOT="$XDG_DATA_HOME/pyenv"

# poetry
POETRY_HOME="$XDG_DATA_HOME/poetry"
POETRY_CONFIG_DIR="$XDG_CONFIG_HOME/poetry"
POETRY_VIRTUALENVS_IN_PROJECT=true

# pipenv
PIPENV_VENV_IN_PROJECT=1
PIPENV_NO_INHERIT=1
PIPENV_IGNORE_VIRTUALENVS=1

# rye
RYE_HOME="$XDG_DATA_HOME/rye"
RYE_NO_AUTO_INSTALL=1

# pdm
PDM_HOME="$XDG_DATA_HOME/pdm"
PDM_USE_VENV=true
PDM_VENV_IN_PROJECT=true

# rbenv
RBENV_ROOT="$XDG_DATA_HOME/rbenv"

# rustup
RUSTUP_HOME="$XDG_DATA_HOME/rustup"
CARGO_HOME="$XDG_DATA_HOME/cargo"

# sdkman
SDKMAN_DIR="$XDG_DATA_HOME/sdkman"
