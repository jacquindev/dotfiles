if ! command -v kubectl >/dev/null; then return; fi

if [ ! -f "$XDG_DATA_HOME/kubernetes/kubectl-aliases/.kubectl_aliases" ]; then
    git clone https://github.com/ahmetb/kubectl-aliases.git "$XDG_DATA_HOME/kubernetes/kubectl-aliases"
fi
source "$XDG_DATA_HOME/kubernetes/kubectl-aliases/.kubectl_aliases"

kj() { 
    k "$@" -o json | jq 
}
kjx() { 
    k "$@" -o json | fx
}
ky() { 
    k "$@" -o yaml | yh 
}